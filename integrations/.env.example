# Supabase (same instance as the main app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hedera Guardian protocol ID (UUID from actions_protocols table)
# Create "Hedera Guardian" in the admin first, then copy its ID here
HEDERA_GUARDIAN_PROTOCOL_ID=uuid-of-hedera-guardian-protocol
